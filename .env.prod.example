# ──────────────────────────────────────────────────────────
#  .env.prod.example — Template pour le VPS
#
#  Sur le VPS :
#    cp .env.prod.example .env
#    chmod 600 .env
#    nano .env   # REMPLACER MONGO_PASSWORD par un secret fort
#
#  Ce fichier ne doit JAMAIS contenir de vrais secrets — il est commité.
#  Le vrai .env est dans .gitignore et reste sur le VPS uniquement.
# ──────────────────────────────────────────────────────────

# ── MongoDB ──
# Compte root de l'instance. Le mot de passe doit être généré :
#   openssl rand -base64 32
MONGO_USER=afribox
MONGO_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# Nom de la base utilisée par le backend (FastAPI)
DB_NAME=afribox

# ── CORS ──
# Liste des origines autorisées à appeler /api (séparées par virgule).
# En prod, le frontend Nginx proxify /api en same-origin — CORS est donc
# surtout utile si tu veux appeler l'API depuis un autre domaine plus tard.
CORS_ORIGINS=https://afriboxlockers.com,https://www.afriboxlockers.com
