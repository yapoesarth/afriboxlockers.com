# Copy this file to .env and adjust as needed.
# `docker compose` reads .env automatically from the project root.

# MongoDB root credentials (change before deploying to VPS!)
MONGO_USER=afribox
MONGO_PASSWORD=changeme

# Database name used by the FastAPI backend
DB_NAME=afribox

# CORS allow-list for the backend. "*" is fine in local since the frontend
# Nginx proxies /api to the backend (same origin). On the VPS, set this to
# your real origin, e.g. https://afribox.example.com
CORS_ORIGINS=*

# Host port for the frontend (Nginx). Open http://localhost:8080 by default.
FRONTEND_PORT=8080
